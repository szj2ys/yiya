# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/yiya

# Stripe payments
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public app URL (used for absolute URLs, Stripe redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (optional) — AI-powered explanations for wrong answers.
# When missing, the app gracefully degrades to static fallback explanations.
OPENAI_API_KEY=sk-...
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Vercel KV (Upstash Redis) — optional.
# When missing, AI cache and rate limiting fall back to in-memory storage.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Web Push (VAPID) — required for push notifications.
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cron secret — protects cron API routes from unauthorized access.
CRON_SECRET=
